#!/bin/sh
# Inject SNMPV3INJECT hook into /etc/init.d/snmpd on first boot.
# Mirrors luci-app-snmp postinst for BSP files-overlay deployments.

INIT="/etc/init.d/snmpd"
MARKER="SNMPV3_INJECT_HOOK"
SNMPV3_CFG="/appdata/FWCONFIG/SNMPV3.json"
SNMPV3_DEFAULT="/appdata/FWCONFIG/SNMPV3.json.default"

# Initialize SNMPV3.json from default if not present
if [ ! -f "$SNMPV3_CFG" ] && [ -f "$SNMPV3_DEFAULT" ]; then
    cp "$SNMPV3_DEFAULT" "$SNMPV3_CFG"
fi

if [ -f "$INIT" ] && ! grep -q "$MARKER" "$INIT" 2>/dev/null; then
    awk -v marker="$MARKER" '
    /^\tprocd_close_instance$/ {
        print "\t# " marker
        print "\t[ -x /usr/local/bin/SNMPV3INJECT ] && /usr/local/bin/SNMPV3INJECT \"$CONFIGFILE\""
    }
    { print }
    ' "$INIT" > "${INIT}.tmp" && mv "${INIT}.tmp" "$INIT" && chmod 755 "$INIT"
fi

/etc/init.d/rpcd reload 2>/dev/null
/etc/init.d/snmpd restart 2>/dev/null

exit 0
