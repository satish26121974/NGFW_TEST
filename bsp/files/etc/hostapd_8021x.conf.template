# hostapd 802.1x config for enterprise WiFi auth
# Managed by orchestrator — configure via LuCI or API
interface=wlan0
driver=nl80211
ssid=UniGr8ways-Enterprise
hw_mode=g
channel=6
wpa=2
wpa_key_mgmt=WPA-EAP
rsn_pairwise=CCMP

# RADIUS server for 802.1x
auth_server_addr=127.0.0.1
auth_server_port=1812
auth_server_shared_secret=testing123

# EAP
eap_server=0
ieee8021x=1
eapol_key_index_workaround=0
