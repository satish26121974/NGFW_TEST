#!/usr/bin/env python3
import socket, hashlib, struct, sys, json, random, os

TAC_PLUS_AUTHEN       = 0x01
TAC_PLUS_AUTHOR       = 0x02
TAC_PLUS_ACCT         = 0x03
AUTHEN_LOGIN          = 0x01
AUTHEN_TYPE_ASCII     = 0x01
AUTHEN_SVC_LOGIN      = 0x01
REPLY_STATUS_PASS     = 0x01
REPLY_STATUS_FAIL     = 0x02
REPLY_STATUS_GETDATA  = 0x05
TAC_MAJOR             = 0xc0
TAC_MINOR_VER_0       = 0x00
HDR_LEN               = 12

def md5_xor(session_id, key, version, seq_no, data):
    key_b = key.encode() if isinstance(key, str) else key
    pad = b""
    last = hashlib.md5(struct.pack(">I", session_id) + key_b +
                       bytes([version, seq_no])).digest()
    while len(pad) < len(data):
        pad += last
        last = hashlib.md5(struct.pack(">I", session_id) + key_b +
                           bytes([version, seq_no]) + last).digest()
    return bytes(a ^ b for a, b in zip(data, pad[:len(data)]))

def build_authen_start(session_id, key, user, password):
    version = TAC_MAJOR | TAC_MINOR_VER_0
    user_b  = user.encode()
    pass_b  = password.encode()
    body = bytes([
        AUTHEN_LOGIN, 0x00, AUTHEN_TYPE_ASCII, AUTHEN_SVC_LOGIN,
        len(user_b), 0x00, 0x00, len(pass_b), 0x00, 0x00
    ]) + user_b + pass_b
    enc_body = md5_xor(session_id, key, version, 1, body)
    header   = struct.pack(">BBBBII",
                           version, TAC_PLUS_AUTHEN, 0x01, 0x00,
                           session_id, len(enc_body))
    return header + enc_body

def parse_reply(data, session_id, key):
    if len(data) < HDR_LEN: return None, None
    version = data[0]
    body_len = struct.unpack(">I", data[8:12])[0]
    enc_body = data[HDR_LEN:HDR_LEN + body_len]
    body     = md5_xor(session_id, key, version, 2, enc_body)
    status   = body[0] if body else 0xFF
    return status, body

def tacacs_auth(server, port, key, user, password, timeout=5):
    session_id = random.randint(1, 0x7fffffff)
    try:
        s = socket.create_connection((server, int(port)), timeout=timeout)
        s.sendall(build_authen_start(session_id, key, user, password))
        resp = s.recv(4096)
        s.close()
        status, body = parse_reply(resp, session_id, key)
        if status == REPLY_STATUS_PASS:  return "PASS"
        if status == REPLY_STATUS_FAIL:  return "FAIL"
        return "ERROR"
    except socket.timeout:
        return "TIMEOUT"
    except Exception as e:
        return "ERROR:%s" % str(e)

if __name__ == "__main__":
    cfg_file = "/appdata/FWCONFIG/TACACS.json"
    if len(sys.argv) < 3:
        print("Usage: TACAUTH <user> <password>"); sys.exit(2)
    user     = sys.argv[1]
    password = sys.argv[2]
    try:
        cfg     = json.load(open(cfg_file))
        if cfg.get("Status", "DISABLE") != "ENABLE":
            print("FALLBACK"); sys.exit(2)
        server  = cfg["Server"]
        port    = cfg.get("Port", 49)
        key     = cfg["Key"]
        result  = tacacs_auth(server, port, key, user, password)
        fallback = cfg.get("LocalFallback", "ENABLE")
        log_line = "TACACS+ user=%s result=%s server=%s" % (user, result, server)
        os.system("logger -t TACAUTH '%s'" % log_line)
        if result == "PASS":
            print("PASS"); sys.exit(0)
        elif result in ("TIMEOUT", "ERROR", "ERROR:") or result.startswith("ERROR:"):
            if fallback == "ENABLE":
                print("FALLBACK"); sys.exit(2)
            print("FAIL"); sys.exit(1)
        else:
            if fallback == "ENABLE":
                print("FALLBACK"); sys.exit(2)
            print("FAIL"); sys.exit(1)
    except FileNotFoundError:
        print("FALLBACK"); sys.exit(2)
    except Exception as e:
        print("FALLBACK"); sys.exit(2)
